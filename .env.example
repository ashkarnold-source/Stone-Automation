# Database — leave blank for local SQLite, set to Railway PostgreSQL URL in production
DATABASE_URL=

# Claude AI (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Gmail OAuth2 (set up at console.cloud.google.com)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# App login (protects the entire app — set a strong password)
ADMIN_USERNAME=ashley
ADMIN_PASSWORD=change-this-to-a-strong-password

# App settings
SECRET_KEY=change-this-to-a-random-string
FROM_EMAIL=your@email.com
FROM_NAME=Ashley Stennis
